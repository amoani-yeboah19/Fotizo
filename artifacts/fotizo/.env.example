# Fotizo frontend environment (Vite only exposes VITE_-prefixed vars to the app).
# Copy to `.env` and adjust. All values are optional; sensible defaults are built in.

# Base URL the API client prepends to every request. Default: /api
# Point this at the backend once it exists, e.g. https://api.fotizo.com or http://localhost:5000/api
VITE_API_BASE_URL=/api

# Data source toggle:
#   true  (default) — serve in-memory mock data; the app runs with no backend.
#   false           — call the real API at VITE_API_BASE_URL.
VITE_USE_MOCKS=true
