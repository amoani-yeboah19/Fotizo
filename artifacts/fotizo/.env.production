# Production build config (public — VITE_ vars are embedded in the client bundle).
# Real auth + product catalog + orders + services (artisans) + messaging against
# the hosted backend; remaining data domains stay mocked until their backend
# endpoints exist (bookings, ...).
VITE_USE_MOCKS=true
VITE_USE_MOCK_AUTH=false
VITE_USE_MOCK_CATALOG=false
VITE_USE_MOCK_ORDERS=false
VITE_USE_MOCK_ARTISANS=false
VITE_USE_MOCK_MESSAGES=false
VITE_API_BASE_URL=https://fotizo.onrender.com/api
