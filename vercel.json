{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @workspace/fotizo run build",
  "installCommand": "pnpm install",
  "outputDirectory": "artifacts/fotizo/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://fotizo.onrender.com/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
